{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@framework-demo/source"],
    "baseUrl": ".",
    "paths": {
      "ui": ["packages/ui/src/index.ts"],
      "form": ["packages/form/src/index.ts"],
      "test": ["modules/test/src/index.ts"]
    }
  }
}
